{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [
      "node",
      "@playwright/test"
    ],
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist"
  },
  "include": [
    "tests",
    "pages"
  ]
}